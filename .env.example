# Copier en .env avant le premier `docker compose up` :
#
#   cp .env.example .env
#   python3 -c 'import secrets;print(f"BIOAI_INTERNAL_KEY={secrets.token_hex(32)}\nBIOAI_ADMIN_KEY={secrets.token_hex(32)}")' > .env
#
# .env n'est jamais commité (voir .gitignore).

# Secret partagé gateway <-> serveurs de modèles. En conteneur, c'est la seule
# barrière qui protège les modèles d'un appel direct : les 6 conteneurs
# doivent avoir la MÊME valeur, et elle doit rester secrète.
BIOAI_INTERNAL_KEY=remplacez-moi-par-un-secret-aleatoire

# Secret d'administration de la gateway : exigé par POST /v1/api-keys, qui
# crée les clés API et fixe leur quota. À garder distinct de la clé interne
# ci-dessus, et à ne jamais distribuer aux utilisateurs — la connaître, c'est
# pouvoir s'attribuer un quota illimité.
BIOAI_ADMIN_KEY=remplacez-moi-par-un-autre-secret-aleatoire

# Cache Hugging Face à monter dans les conteneurs (poids des modèles).
# Défaut : /data_local/hf_cache
#HF_CACHE_DIR=/data_local/hf_cache
